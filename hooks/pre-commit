#!/bin/bash

# Git pre-commit钩子：提交前执行SQL离线校验
echo "===== 开始执行SQL离线校验 ====="

# 1. 定义SQL校验JAR的路径（替换为你实际的JAR路径）
SQL_CHECKER_JAR="${PWD}/scripts/hook4-1.0-SNAPSHOT-jar-with-dependencies.jar"

# 2. 定义需要校验的代码目录（项目根目录下的src）
CODE_PATH="${PWD}/src/main/java/com/example/mybatis"

# 3. 执行SQL校验工具
java -jar -Dfile.encoding=utf-8 "${SQL_CHECKER_JAR}" -p "${CODE_PATH}"

# 4. 判断校验结果：退出码非0则终止提交
if [ $? -ne 0 ]; then
    echo "===== SQL校验失败，终止提交 ====="
    exit 1
else
    echo "===== SQL校验通过，继续提交 ====="
    exit 0
fi